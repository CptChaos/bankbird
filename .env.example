APP_NAME=BankBird
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Amsterdam
APP_URL=http://localhost

APP_LOCALE=nl
APP_FALLBACK_LOCALE=nl
APP_FAKER_LOCALE=nl_NL

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

DEMO_MODE=false

# Lokale gecombineerde host: laat onverstoord in productie. Lokaal serveert
# deze host marketing op /, demo-paneel op /demo en admin op /dev.
LOCAL_HOST=bankbird.app.test

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# LOKAAL gebruik (standaard): twee SQLite-bestanden — eentje voor het demo-
# paneel en eentje voor het admin-paneel. De default staat op sqlite_dev,
# een middleware schakelt naar sqlite_demo zodra de URL met /demo begint.
DB_CONNECTION=sqlite_dev

# ONLINE gebruik: schakel bovenstaande uit en gebruik onderstaande MySQL configuratie.
# Zorg dat de databaseserver TLS/SSL en versleuteling at-rest ingeschakeld heeft.
#DB_CONNECTION=mysql
#DB_HOST=127.0.0.1
#DB_PORT=3306
#DB_DATABASE=bankbird
#DB_USERNAME=bankbird
#DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
